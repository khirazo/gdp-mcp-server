# GDP MCP Server - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================================
# Required: GDP Connection Settings
# ============================================================

# GDP appliance hostname or IP address
GDP_HOST=your-gdp-appliance.example.com

# GDP REST API port (default: 8443)
GDP_PORT=8443

# ============================================================
# Required: GDP OAuth2 Credentials
# ============================================================

# OAuth2 client ID (from 'grdapi register_oauth_client')
GDP_CLIENT_ID=your_client_id

# OAuth2 client secret (from 'grdapi register_oauth_client')
GDP_CLIENT_SECRET=your_client_secret

# GDP admin username
GDP_USERNAME=admin

# GDP admin password
GDP_PASSWORD=your_password

# ============================================================
# Optional: External Access (Cloud/NAT/Tunnel)
# ============================================================

# Use these when accessing GDP through a proxy, NAT, or tunnel
# If set, these override GDP_HOST and GDP_PORT
#GDP_EXTERNAL_HOST=proxy.example.com
#GDP_EXTERNAL_PORT=8443

# ============================================================
# Optional: GuardCLI (SSH) Settings
# ============================================================

# GuardCLI SSH password (enables gdp_guard_cli tool)
# If not set, GuardCLI features will be disabled
#GDP_CLI_PASS=your_cli_password

# GuardCLI SSH host (defaults to GDP_HOST if not set)
#GDP_CLI_HOST=your-gdp-appliance.example.com

# GuardCLI SSH port (default: 2222)
#GDP_CLI_PORT=2222

# GuardCLI SSH username (default: cli)
#GDP_CLI_USER=cli

# ============================================================
# Optional: Multi-Appliance Support
# ============================================================

# Comma-separated list of appliance names
# Example: GDP_APPLIANCES=cm01,cm02,collector01
#GDP_APPLIANCES=

# Per-appliance settings (prefix with GDP_<NAME>_)
# Example for appliance "cm01":
#GDP_CM01_HOST=cm01.example.com
#GDP_CM01_PORT=8443
#GDP_CM01_CLIENT_ID=cm01_client
#GDP_CM01_CLIENT_SECRET=cm01_secret
#GDP_CM01_USERNAME=admin
#GDP_CM01_PASSWORD=password
#GDP_CM01_CLI_PASS=cli_password

# Example for appliance "cm02":
#GDP_CM02_HOST=cm02.example.com
#GDP_CM02_PORT=8443
# ... (same pattern as cm01)

# ============================================================
# Optional: SSL and Security
# ============================================================

# SSL certificate verification (default: false)
# Set to true if your GDP appliance has a valid SSL certificate
GDP_VERIFY_SSL=false

# ============================================================
# Optional: Performance and Logging
# ============================================================

# HTTP request timeout in seconds (default: 60)
GDP_REQUEST_TIMEOUT=60

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# ============================================================
# Optional: MCP Transport Settings
# ============================================================

# Transport mode: stdio or streamable-http (default: stdio)
MCP_TRANSPORT=stdio

# Streamable HTTP settings (only used when MCP_TRANSPORT=streamable-http)
#MCP_HOST=0.0.0.0
#MCP_PORT=8003

# API key store path (only used in streamable-http mode)
#GDP_MCP_KEY_STORE_PATH=/data/keys.json